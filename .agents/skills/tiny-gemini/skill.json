{
	"name": "tiny-gemini",
	"version": "2.0.0",
	"description": "Suite core for the tiny-gemini NPX CLI. Covers text Q&A, search-grounded answers, and the raw Gemini API passthrough. Bundles four satellites for image, TTS, deep research, and offline model lookup.",
	"keywords": [
		"ai",
		"api",
		"gemini",
		"google",
		"cli",
		"suite-core"
	],
	"type": "skill",
	"repository": "https://github.com/nicolasdao/tiny-gemini",
	"dependencies": {
		"nicolasdao/tiny-gemini-image": "^0.1.0",
		"nicolasdao/tiny-gemini-tts": "^0.1.0",
		"nicolasdao/tiny-gemini-research": "^0.1.0",
		"nicolasdao/tiny-gemini-models": "^0.1.0"
	},
	"systemDependencies": {
		"node": {
			"description": "Node.js runtime",
			"version": ">=18.0.0",
			"check": "node --version",
			"install": {
				"darwin": "brew install node",
				"linux": "curl -fsSL https://deb.nodesource.com/setup_lts.x | sudo -E bash - && sudo apt-get install -y nodejs",
				"win32": "winget install OpenJS.NodeJS.LTS"
			}
		},
		"npx": {
			"description": "NPX package runner (bundled with Node.js)",
			"version": ">=8.0.0",
			"check": "npx --version",
			"install": {
				"darwin": "Included with Node.js installation",
				"linux": "Included with Node.js installation",
				"win32": "Included with Node.js installation"
			}
		}
	}
}
